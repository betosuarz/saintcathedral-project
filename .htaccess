<IfModule mod_rewrite.c>
  RewriteEngine On

  # Forzar HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # ── Redirecciones 301 del WordPress antiguo (URLs heredadas) ──
  # Versión inglesa WPML: /en, /en/, /en/lo-que-sea → home
  RewriteRule ^en(/.*)?$ / [R=301,L]
  # Home antigua → home canónica
  RewriteRule ^inicio/?$ / [R=301,L]
  # Audioguía antigua → menú de audioguía actual
  RewriteRule ^audioguia-can-ita/?$ /audioguia/menu-audioguia.html [R=301,L]
  # Boletín parroquial (PDF en wp-content) → página de institución
  RewriteRule ^wp-content/uploads/2026/05/BOLETIN_2738\.pdf$ /institucion [R=301,L]
  # Cualquier otro resto de WordPress (uploads, wp-admin, etc.) → home
  RewriteRule ^wp-(content|admin|includes|json)(/.*)?$ / [R=301,L]

  # Redirect 301: /index.html y /index → / (URL canónica raíz)
  RewriteCond %{THE_REQUEST} \s/index(\.html)?[\s?] [NC]
  RewriteRule ^index(\.html)?$ / [R=301,L]

  # Redirect 301: /pagina.html → /pagina  (la URL pública pierde el .html)
  # Se excluye /audioguia/ (sub-app con navegación propia por querystring)
  RewriteCond %{REQUEST_URI} !^/audioguia/ [NC]
  RewriteCond %{THE_REQUEST} \s/(.+?)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # Servir el .html real cuando se pide la URL sin extensión
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# No añadir barra automática a directorios: deja que /monumentos sirva
# monumentos.html aunque exista también la carpeta monumentos/
DirectorySlash Off

# Deshabilitar listado de directorios
Options -Indexes

# Página de error 404 personalizada (opcional, descomenta si creas la página)
# ErrorDocument 404 /404.html
